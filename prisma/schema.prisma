generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Story {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Gallery {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  category  String   @default("General")
  createdAt DateTime @default(now())
}

model RSVP {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String
  status    String   // e.g., "attending", "not_attending"
  message   String?
  createdAt DateTime @default(now())
}

model EventDetail {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  date      String
  time      String
  location  String
  dressCode String
  order     Int      @default(0)
}

model SupportDetail {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  currency    String // "NGN" or "USD"
  bank        String
  accountNum  String
  accountName String
  symbol      String
}
